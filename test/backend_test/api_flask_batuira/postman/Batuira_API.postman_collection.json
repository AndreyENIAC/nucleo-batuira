{
  "info": {
    "name": "Núcleo Batuíra API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "base_url", "value": "http://127.0.0.1:5000/api"},
    {"key": "token", "value": ""}
  ],
  "item": [
    {
      "name": "Autenticação",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body": {"mode":"raw","raw":"{\n  \"login\": \"admin\",\n  \"senha\": \"admin123\"\n}"},
            "url": "{{base_url}}/auth/login"
          }
        },
        {
          "name": "Trocar senha",
          "request": {
            "method": "POST",
            "header": [
              {"key":"Content-Type","value":"application/json"},
              {"key":"Authorization","value":"Bearer {{token}}"}
            ],
            "body": {"mode":"raw","raw":"{\n  \"nova_senha\": \"NovaSenha123\",\n  \"confirmacao\": \"NovaSenha123\"\n}"},
            "url": "{{base_url}}/auth/trocar-senha"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [{"key":"Authorization","value":"Bearer {{token}}"}],
        "url": "{{base_url}}/dashboard"
      }
    },
    {
      "name": "Acolhidos",
      "item": [
        {
          "name": "Listar",
          "request": {"method":"GET","header":[{"key":"Authorization","value":"Bearer {{token}}"}],"url":"{{base_url}}/acolhidos"}
        },
        {
          "name": "Cadastrar",
          "request": {
            "method":"POST",
            "header":[{"key":"Authorization","value":"Bearer {{token}}"},{"key":"Content-Type","value":"application/json"}],
            "body":{"mode":"raw","raw":"{\n  \"nome\": \"Maria da Silva\",\n  \"data_nascimento\": \"1948-03-15\",\n  \"modalidade_acolhimento\": \"idoso\",\n  \"data_admissao\": \"2026-07-15\",\n  \"status\": \"estavel\"\n}"},
            "url":"{{base_url}}/acolhidos"
          }
        }
      ]
    },
    {
      "name": "Rotas disponíveis",
      "request": {"method":"GET","url":"{{base_url}}/rotas"}
    }
  ]
}
